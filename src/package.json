{
    "name": "memoria",
    "displayName": "Memoria",
    "description": "Scaffold a personal knowledge base in a workspace - organize notes, meetings, contacts, and TODOs with optional Copilot integration.",
    "version": "0.0.1",
    "publisher": "RazMake",
    "repository": {
        "type": "git",
        "url": "https://github.com/RazMake/Memoria"
    },
    "license": "Elastic-2.0",
    "engines": {
        "vscode": "^1.116.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:.memoria/blueprint.json",
        "onCustomEditor:memoria.todoEditor"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "memoria.initializeWorkspace",
                "title": "Initialize workspace",
                "category": "Memoria"
            },
            {
                "command": "memoria.toggleDotFolders",
                "title": "Toggle dot-folders",
                "category": "Memoria"
            },
            {
                "command": "memoria.manageFeatures",
                "title": "Manage features",
                "category": "Memoria"
            },
            {
                "command": "memoria.openDefaultFile",
                "title": "Open default file(s)",
                "category": "Memoria"
            },
            {
                "command": "memoria.syncTasks",
                "title": "Sync Tasks",
                "category": "Memoria"
            },
            {
                "command": "memoria.addPerson",
                "title": "Add Person",
                "category": "Memoria"
            },
            {
                "command": "memoria.editPerson",
                "title": "Edit Person",
                "category": "Memoria"
            },
            {
                "command": "memoria.deletePerson",
                "title": "Delete Person",
                "category": "Memoria"
            },
            {
                "command": "memoria.movePerson",
                "title": "Move Person",
                "category": "Memoria"
            },
            {
                "command": "memoria.openUserGuide",
                "title": "Open User Guide",
                "category": "Memoria"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "memoria-contacts",
                    "title": "Contacts",
                    "icon": "resources/media/contacts-view.svg"
                }
            ]
        },
        "views": {
            "memoria-contacts": [
                {
                    "type": "webview",
                    "id": "memoria.contactsView",
                    "name": "Contacts",
                    "when": "memoria.contactsActive"
                }
            ]
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "memoria.initializeWorkspace"
                },
                {
                    "command": "memoria.toggleDotFolders",
                    "when": "memoria.workspaceInitialized"
                },
                {
                    "command": "memoria.manageFeatures",
                    "when": "memoria.workspaceInitialized"
                },
                {
                    "command": "memoria.syncTasks",
                    "when": "memoria.workspaceInitialized"
                },
                {
                    "command": "memoria.addPerson",
                    "when": "memoria.contactsActive"
                },
                {
                    "command": "memoria.editPerson",
                    "when": "memoria.contactsActive"
                },
                {
                    "command": "memoria.deletePerson",
                    "when": "memoria.contactsActive"
                },
                {
                    "command": "memoria.movePerson",
                    "when": "memoria.contactsActive && memoria.contactsMultiGroup"
                },
                {
                    "command": "memoria.openUserGuide"
                },
                {
                    "command": "memoria.openDefaultFile",
                    "when": "false"
                }
            ],
            "explorer/context": [
                {
                    "command": "memoria.openDefaultFile",
                    "when": "memoria.defaultFileAvailable && explorerResourceIsFolder && resource in memoria.defaultFileFolders",
                    "group": "navigation"
                }
            ]
        },
        "customEditors": [
            {
                "viewType": "memoria.todoEditor",
                "displayName": "Memoria Todo Editor",
                "selector": [
                    {
                        "filenamePattern": "*.todo.md"
                    }
                ],
                "priority": "default"
            }
        ]
    },
    "scripts": {
        "postinstall": "patch-package",
        "prebuild": "node -e \"require('fs').existsSync('node_modules')||process.exit(1)\" || npm install",
        "build": "node esbuild.config.mjs",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:coverage:all": "vitest run --coverage --coverage.reportsDirectory=coverage/unit && npm run pretest:integration && vscode-test --coverage --coverage-output coverage/e2e",
        "compile:tests": "tsc -p ../tests/e2e-tests/tsconfig.json",
        "pretest:integration": "npm run build && npm run compile:tests",
        "test:integration": "vscode-test",
        "package": "vsce package --out ../publish/",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --ext .ts"
    },
    "dependencies": {
        "@vscode/codicons": "^0.0.45",
        "@vscode/extension-telemetry": "^1.5.1",
        "ajv": "^8.18.0",
        "jsonc-parser": "^3.3.1",
        "markdown-it": "^14.1.1",
        "markdown-it-task-lists": "^2.1.1",
        "minimatch": "^10.2.5",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@types/markdown-it": "^14.1.2",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.6.0",
        "@types/vscode": "^1.116.0",
        "@vitest/coverage-istanbul": "^4.1.4",
        "@vitest/coverage-v8": "^4.1.4",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "mocha": "^11.7.5",
        "patch-package": "^8.0.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.4"
    }
}
