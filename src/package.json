{
    "name": "memoria",
    "displayName": "Memoria",
    "description": "Scaffold a personal knowledge base in a workspace - organize notes, meetings, contacts, and TODOs with optional Copilot integration.",
    "version": "0.0.1",
    "publisher": "TODO_PUBLISHER_ID",
    "engines": {
        "vscode": "^1.100.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "workspaceContains:.memoria/blueprint.json"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "memoria.initializeWorkspace",
                "title": "Initialize workspace",
                "category": "Memoria"
            },
            {
                "command": "memoria.toggleDotFolders",
                "title": "Toggle dot-folders",
                "category": "Memoria"
            },
            {
                "command": "memoria.manageFeatures",
                "title": "Manage features",
                "category": "Memoria"
            },
            {
                "command": "memoria.openDefaultFile",
                "title": "Open default file(s)",
                "category": "Memoria"
            },
            {
                "command": "memoria.openUserGuide",
                "title": "Open User Guide",
                "category": "Memoria"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "memoria.initializeWorkspace"
                },
                {
                    "command": "memoria.toggleDotFolders",
                    "when": "memoria.workspaceInitialized"
                },
                {
                    "command": "memoria.manageFeatures",
                    "when": "memoria.workspaceInitialized"
                },
                {
                    "command": "memoria.openUserGuide"
                },
                {
                    "command": "memoria.openDefaultFile",
                    "when": "false"
                }
            ],
            "explorer/context": [
                {
                    "command": "memoria.openDefaultFile",
                    "when": "memoria.defaultFileAvailable && explorerResourceIsFolder && resource in memoria.defaultFileFolders",
                    "group": "navigation"
                }
            ]
        },
        "walkthroughs": [
            {
                "id": "memoria.getStarted",
                "title": "Get Started with Memoria",
                "description": "Set up your personal knowledge base in a few steps.",
                "steps": [
                    {
                        "id": "welcome",
                        "title": "Welcome to Memoria",
                        "description": "Memoria scaffolds a personal knowledge base inside your workspace — organized folders for notes, meetings, contacts, and TODOs.\n\n[Open User Guide](command:memoria.openUserGuide)",
                        "media": {
                            "markdown": "resources/walkthrough/welcome.md"
                        }
                    },
                    {
                        "id": "initializeWorkspace",
                        "title": "Initialize Your Workspace",
                        "description": "Run the initialize command to pick a blueprint template and scaffold your knowledge base.\n\n[Initialize Workspace](command:memoria.initializeWorkspace)",
                        "media": {
                            "markdown": "resources/walkthrough/initialize.md"
                        }
                    },
                    {
                        "id": "exploreStructure",
                        "title": "Explore Your Knowledge Base",
                        "description": "Browse the folders Memoria created in the Explorer. Each folder serves a specific purpose — TODOs, meeting notes, contacts, and more.",
                        "media": {
                            "markdown": "resources/walkthrough/explore.md"
                        }
                    },
                    {
                        "id": "openDefaultFiles",
                        "title": "Open Default Files",
                        "description": "Right-click any folder with a configured default file and select **Open default file(s)** to quickly open your most-used files side by side.",
                        "media": {
                            "markdown": "resources/walkthrough/default-files.md"
                        }
                    },
                    {
                        "id": "toggleDotFolders",
                        "title": "Hide Configuration Folders",
                        "description": "Use **Toggle dot-folders** to hide `.memoria/` and other dot-folders from the Explorer for a cleaner view.\n\n[Toggle Dot-Folders](command:memoria.toggleDotFolders)",
                        "media": {
                            "markdown": "resources/walkthrough/toggle-dot-folders.md"
                        }
                    },
                    {
                        "id": "learnMore",
                        "title": "Learn More",
                        "description": "Open the full User Guide for detailed documentation on all commands, features, and blueprints.\n\n[Open User Guide](command:memoria.openUserGuide)",
                        "media": {
                            "markdown": "resources/walkthrough/learn-more.md"
                        }
                    }
                ]
            }
        ]
    },
    "scripts": {
        "postinstall": "patch-package",
        "prebuild": "npm install",
        "build": "node esbuild.config.mjs",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:coverage:all": "vitest run --coverage --coverage.reportsDirectory=coverage/unit && npm run pretest:integration && vscode-test --coverage --coverage-output coverage/e2e",
        "compile:tests": "tsc -p ../tests/e2e-tests/tsconfig.json",
        "pretest:integration": "npm run build && npm run compile:tests",
        "test:integration": "vscode-test",
        "package": "vsce package --out ../publish/"
    },
    "dependencies": {
        "@vscode/extension-telemetry": "^0.9.8",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.0",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.100.0",
        "@vitest/coverage-istanbul": "^3.2.4",
        "@vitest/coverage-v8": "^3.1.1",
        "@vscode/test-cli": "^0.0.8",
        "@vscode/test-electron": "^2.4.1",
        "@vscode/vsce": "^3.3.2",
        "esbuild": "^0.25.2",
        "mocha": "^11.0.0",
        "patch-package": "^8.0.1",
        "typescript": "^5.8.3",
        "vitest": "^3.1.1"
    }
}
