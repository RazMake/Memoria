{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "backup-config.schema.json",
  "title": "Memoria Backup Configuration",
  "description": "Scheduled backup profiles for the Memoria VS Code extension.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profiles": {
      "type": "object",
      "description": "Named backup profile definitions.",
      "additionalProperties": {
        "$ref": "#/definitions/BackupProfile"
      }
    },
    "_state": {
      "type": "object",
      "description": "Internal runtime state — do not edit manually.",
      "additionalProperties": {
        "$ref": "#/definitions/BackupProfileState"
      }
    }
  },
  "required": ["profiles"],
  "additionalProperties": false,
  "definitions": {
    "BackupProfile": {
      "type": "object",
      "description": "A named backup profile.",
      "properties": {
        "sources": {
          "type": "array",
          "description": "Workspace-relative glob patterns or folder paths to include.",
          "items": { "type": "string" },
          "minItems": 1
        },
        "exclude": {
          "type": "array",
          "description": "Glob patterns to exclude from sources.",
          "items": { "type": "string" },
          "default": []
        },
        "targetFolder": {
          "type": "string",
          "description": "Absolute filesystem path to the folder where backup zips are written."
        },
        "schedule": {
          "$ref": "#/definitions/BackupSchedule"
        },
        "retention": {
          "type": "integer",
          "description": "Maximum number of backup zips to keep per profile. Oldest are deleted first.",
          "minimum": 1,
          "default": 7
        }
      },
      "required": ["sources", "targetFolder", "schedule", "retention"],
      "additionalProperties": false
    },
    "BackupSchedule": {
      "type": "object",
      "description": "When to run the backup.",
      "properties": {
        "time": {
          "type": "string",
          "description": "Time of day in HH:MM (24-hour) format.",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "examples": ["18:00", "09:00", "23:30"]
        },
        "days": {
          "type": "array",
          "description": "Days of the week to run the backup.",
          "items": {
            "type": "string",
            "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["time", "days"],
      "additionalProperties": false
    },
    "BackupProfileState": {
      "type": "object",
      "description": "Runtime state for a backup profile — managed automatically.",
      "properties": {
        "lastBackupTime": {
          "type": ["string", "null"],
          "description": "ISO 8601 timestamp of last successful backup."
        },
        "hashes": {
          "type": "object",
          "description": "Map of workspace-relative path to SHA-256 hex digest.",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  }
}
