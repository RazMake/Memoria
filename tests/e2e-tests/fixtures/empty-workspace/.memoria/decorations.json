{
  "rules": [
    {
      "filter": ".*/",
      "color": "terminal.ansiBrightBlack"
    },
    {
      "filter": "05-Autocomplete/Snippets/",
      "color": "terminal.ansiCyan",
      "badge": "✂️",
      "tooltip": "User-defined text expansion snippets.",
      "propagate": true
    },
    {
      "filter": "Dev-Designs/",
      "color": "charts.purple",
      "badge": "🪛",
      "tooltip": "Dev design documents, grouped by quarter.",
      "propagate": true
    },
    {
      "filter": "00-Workstreams/",
      "color": "terminal.ansiMagenta",
      "badge": "📋",
      "tooltip": "Information about current workstreams, todos, etc.",
      "propagate": true
    },
    {
      "filter": "01-ToRemember/",
      "color": "charts.yellow",
      "badge": "🧠",
      "tooltip": "Personal knowledge base.",
      "propagate": true
    },
    {
      "filter": "02-MeetingNotes/",
      "color": "terminal.ansiBrightYellow",
      "tooltip": "Meeting notes to be preserved for later references.",
      "propagate": true
    },
    {
      "filter": "03-Inbox/",
      "color": "charts.red",
      "badge": "📭",
      "tooltip": "New, unprocessed notes.",
      "propagate": true
    },
    {
      "filter": "04-Archive/",
      "color": "terminal.ansiBrightBlack",
      "badge": "⌛",
      "tooltip": "Notes/information that is considered obsolete, but the user decided to keep it around for a bit longer.",
      "propagate": true
    },
    {
      "filter": "05-Autocomplete/Contacts/DataTypes/",
      "color": "terminal.ansiBlue",
      "badge": "🔨",
      "tooltip": "Data types used in contact definitions.",
      "propagate": true
    },
    {
      "filter": "05-Autocomplete/Contacts/InterviewTemplates/",
      "color": "terminal.ansiRed",
      "badge": "📋",
      "tooltip": "Problems that can be used in an interview.",
      "propagate": true
    },
    {
      "filter": "05-Autocomplete/Contacts/",
      "color": "terminal.ansiGreen",
      "badge": "👤",
      "tooltip": "Known contacts information, available in this workspace.",
      "propagate": true
    },
    {
      "filter": "05-Autocomplete/",
      "color": "terminal.ansiBrightBlack",
      "badge": "🤖",
      "tooltip": "Autocomplete features: contacts, snippets, and more.",
      "propagate": true
    },
    {
      "filter": "WorkspaceInitializationBackups/",
      "color": "terminal.ansiBrightBlack",
      "tooltip": "Backup of files that existed before the scaffolding of the workspace.",
      "propagate": true
    }
  ]
}