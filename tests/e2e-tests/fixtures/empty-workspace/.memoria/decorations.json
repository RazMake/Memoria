{
  "rules": [
    {
      "filter": ".*/",
      "color": "terminal.ansiBrightBlack"
    },
    {
      "filter": "00-Workstreams/",
      "color": "terminal.ansiMagenta",
      "badge": "📋",
      "tooltip": "Information about current workstreams, todos, etc.",
      "propagate": true
    },
    {
      "filter": "01-MeetingNotes/",
      "color": "charts.green",
      "tooltip": "Meeting notes to be preserved for later references.",
      "propagate": true
    },
    {
      "filter": "02-Inbox/",
      "color": "charts.red",
      "badge": "📭",
      "tooltip": "New, unprocessed notes.",
      "propagate": true
    },
    {
      "filter": "03-ToRemember/",
      "color": "terminal.ansiBrightYellow",
      "badge": "🧠",
      "tooltip": "Personal knowledge base.",
      "propagate": true
    },
    {
      "filter": "04-Archive/",
      "color": "terminal.ansiBrightBlack",
      "tooltip": "Notes from previous years.",
      "propagate": true
    },
    {
      "filter": "10-Autocomplete/Contacts/DataTypes/",
      "color": "terminal.ansiBlue",
      "badge": "🔨",
      "tooltip": "Data types used in contact definitions.",
      "propagate": true
    },
    {
      "filter": "10-Autocomplete/Snippets/",
      "color": "terminal.ansiCyan",
      "badge": "✂️",
      "tooltip": "User-defined text expansion snippets.",
      "propagate": true
    },
    {
      "filter": "10-Autocomplete/",
      "color": "terminal.ansiBrightBlack",
      "badge": "🤖",
      "tooltip": "Autocomplete features: contacts, snippets, and more.",
      "propagate": true
    },
    {
      "filter": "11-Templates/",
      "color": "terminal.ansiBrightBlack",
      "badge": "🤖",
      "tooltip": "Autocomplete features: contacts, snippets, and more.",
      "propagate": true
    },
    {
      "filter": "12-Settings/",
      "color": "terminal.ansiBrightBlack",
      "badge": "🤖",
      "tooltip": "Various settings files.",
      "propagate": true
    },
    {
      "filter": "13-Scripts/",
      "color": "terminal.ansiBrightBlack",
      "badge": "🤖",
      "tooltip": "Script files used in the workspace, even by skills.",
      "propagate": true
    },
    {
      "filter": "WorkspaceInitializationBackups/",
      "color": "terminal.ansiBrightBlack",
      "tooltip": "Backup of files that existed before the scaffolding of the workspace.",
      "propagate": true
    }
  ]
}