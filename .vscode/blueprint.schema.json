{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "memoria-blueprint",
  "title": "Memoria Blueprint",
  "description": "Schema for Memoria workspace blueprint definition files.",
  "type": "object",
  "required": ["id", "name", "description", "version", "workspace"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the blueprint."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable display name shown in the QuickPick."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Short description of the blueprint's purpose."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the blueprint (e.g. 1.0.0)."
    },
    "workspace": {
      "type": "array",
      "minItems": 1,
      "description": "Top-level workspace entries to scaffold. Folder names must end with '/'.",
      "items": { "$ref": "#/$defs/workspaceEntry" }
    },
    "decorations": {
      "type": "array",
      "description": "Optional file decoration rules applied after scaffolding.",
      "items": { "$ref": "#/$defs/decorationRule" }
    }
  },
  "$defs": {
    "workspaceEntry": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Entry name. Append '/' to denote a folder (e.g. '00-ToDo/'). Files must not have children."
        },
        "children": {
          "type": "array",
          "description": "Nested entries (folders only).",
          "items": { "$ref": "#/$defs/workspaceEntry" }
        }
      }
    },
    "decorationRule": {
      "type": "object",
      "required": ["filter"],
      "additionalProperties": false,
      "properties": {
        "filter": {
          "type": "string",
          "minLength": 1,
          "description": "Path substring matched against workspace-relative paths to select decorated entries."
        },
        "color": {
          "type": "string",
          "minLength": 1,
          "description": "VS Code theme color identifier (e.g. 'charts.yellow')."
        },
        "badge": {
          "type": "string",
          "maxLength": 2,
          "description": "Short badge text (1–2 characters) shown on the file decoration."
        }
      }
    }
  }
}
